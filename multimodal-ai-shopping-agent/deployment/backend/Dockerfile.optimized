# Multi-stage optimized Docker build for Bringo Backend API
# Optimized for Cloud Build with Kaniko layer caching

# ============================================================
# Stage 1: Base Image with System Dependencies
# ============================================================
FROM python:3.11-slim AS base

# Install system dependencies (CACHED - rarely changes)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    curl \
    gnupg \
    wget \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Install Chrome for Selenium (CACHED - rarely changes)
RUN wget -q -O /tmp/google-chrome-stable_current_amd64.deb \
    https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb && \
    apt-get update && \
    apt-get install -y /tmp/google-chrome-stable_current_amd64.deb && \
    rm /tmp/google-chrome-stable_current_amd64.deb && \
    rm -rf /var/lib/apt/lists/*

# ============================================================
# Stage 2: Python Dependencies
# ============================================================
FROM base AS dependencies

WORKDIR /app

# Copy requirements first (CACHED - only rebuilds if requirements.txt changes)
COPY requirements.txt .

# Install uv for faster pip installs (10-100x faster)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /bin/uv

# Install Python dependencies with cache mount
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system -r requirements.txt

# ============================================================
# Stage 3: Application Code
# ============================================================
FROM dependencies AS app

WORKDIR /app

# Copy config and database (changes occasionally)
COPY config ./config
COPY database ./database

# Copy services (changes occasionally)
COPY services ./services

# Copy ML/search modules (changes occasionally)
COPY vector_search ./vector_search
COPY embeddings ./embeddings
COPY features ./features
COPY ranking ./ranking
COPY substitution ./substitution
COPY data ./data

# Copy security module
COPY security ./security

# Copy API code (changes frequently)
COPY api ./api

# Copy root files
COPY *.py ./

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

# Run the application
CMD ["python", "api/main.py"]
