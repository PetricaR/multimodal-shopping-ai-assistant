# Bringo Agent Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================
# Database Configuration
# ============================================

# Database Type: Set to 'true' for PostgreSQL, 'false' for SQLite
USE_POSTGRES=false

# PostgreSQL Configuration (only needed if USE_POSTGRES=true)
# For Cloud Run, use Unix socket: /cloudsql/PROJECT:REGION:INSTANCE
# For local with proxy, use: localhost
DB_HOST=/cloudsql/formare-ai:europe-west1:bringo-db
DB_PORT=5432
DB_NAME=bringo_auth
DB_USER=bringo_user
DB_PASSWORD=  # Get from: gcloud secrets versions access latest --secret=bringo-db-password

# ============================================
# Bringo Credentials
# ============================================

BRINGO_USERNAME=your-email@example.com
BRINGO_PASSWORD=your-password
BRINGO_STORE=carrefour_park_lake
BRINGO_BASE_URL=https://www.bringo.ro

# ============================================
# Session Worker Configuration
# ============================================

# How many minutes before expiration to refresh the session
SESSION_REFRESH_BUFFER_MINUTES=30

# How often (in seconds) the worker checks for sessions needing refresh
SESSION_POLL_INTERVAL_SECONDS=60

# How often (in minutes) to validate session with Bringo server
SESSION_VALIDATE_INTERVAL_MINUTES=15

# Set to 'false' when using worker pool (to avoid latency)
# Set to 'true' if NOT using worker pool (validates on each request)
ENABLE_SESSION_VALIDATION_ON_REQUEST=false

# ============================================
# Google Cloud Configuration
# ============================================

GCP_PROJECT_ID=formare-ai
GCP_REGION=europe-west1
PROJECT_ID=formare-ai
LOCATION=europe-west1

# ============================================
# API Configuration
# ============================================

API_PORT=8080
API_HOST=0.0.0.0
API_AUTH_KEY=your-api-key-here

# ============================================
# Google AI Configuration
# ============================================

GOOGLE_API_KEY=your-google-ai-api-key

# ============================================
# BigQuery Configuration
# ============================================

BQ_DATASET=bringo_products_data
BQ_TABLE=bringo_products_native
BQ_OUTPUT_DATASET=bringo_similarity_search_multimodal

# ============================================
# Vector Search Configuration
# ============================================

VS_INDEX_NAME=bringo-product-index-multimodal
VS_ENDPOINT_NAME=bringo-product-endpoint-multimodal
VS_DEPLOYED_INDEX_ID=bringo_products_multimodal_deployed

# ============================================
# Feature Store Configuration
# ============================================

FS_PUBLIC_ENDPOINT=527765581332480.europe-west1-845266575866.featurestore.vertexai.goog
FS_METADATA_VIEW=bringo_product_metadata

# ============================================
# Development & Testing
# ============================================

# Set to 'true' to enable debug logging
DEBUG=false

# Set to 'true' to skip authentication (for testing only!)
SKIP_AUTH=false
